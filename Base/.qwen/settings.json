{
  "// NOTE": "MCP Servers configuration for Qwen Code",
  "// DOC": "https://qwenlm.github.io/qwen-code-docs/en/users/features/mcp/",
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "D:\\QwenPoekt",
        "D:\\QwenPoekt\\Base",
        "D:\\QwenPoekt\\Projects",
        "D:\\QwenPoekt\\_BACKUP",
        "D:\\QwenPoekt\\_TEST_ENV"
      ],
      "disabled": false,
      "alwaysAllow": [
        "read_file",
        "list_directory",
        "get_file_info",
        "search_files"
      ],
      "readOnly": false,
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=32768",
        "V8_MAX_HEAP_SIZE": "32768"
      }
    }
  },
  "workspace": {
    "maxFileSize": "100MB",
    "maxContextFiles": 1000,
    "cacheEnabled": true,
    "cacheSizeMB": 16384
  },
  "$version": 3
}